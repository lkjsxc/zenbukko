{
  "name": "course-archive-toolkit",
  "private": true,
  "description": "Local course archive and transcription toolkit (Node 22 + TypeScript)",
  "type": "module",
  "bin": {
    "zenbukko": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:ui",
    "build:ui": "npm --prefix web-ui install && npm --prefix web-ui run build",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/index.ts",
    "cli": "node dist/index.js",
    "api": "node dist/index.js api",
    "web": "node dist/index.js web",
    "build:docker": "docker compose build zenbukko-api zenbukko-web",
    "ci:docker": "docker compose build zenbukko-api zenbukko-web",
    "lint": "eslint .",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "smoke:local-ocr": "tsx scripts/smoke-local-ocr.ts",
    "check:lines": "tsx scripts/check-lines.ts",
    "format": "prettier -w ."
  },
  "dependencies": {
    "cheerio": "1.0.0-rc.12",
    "commander": "^13.0.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.2.0",
    "puppeteer": "^23.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
